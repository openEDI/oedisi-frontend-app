        "measurement_file": {
          "title": "Measurement File",
          "type": "string"
        },
        "run_freq_time_step": {
          "default": 1.0,
          "title": "Run Freq Time Step",
          "type": "number",
          "minimum": 0.0
        }
      },
      "required": [
        "measurement_file"
      ],
      "title": "MeasurementConfig",
      "type": "object"
    }
  },
