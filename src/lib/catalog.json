[
  {
    "id": "Feeder",
    "name": "Feeder",
    "description": "OpenDSS simulation engine",
    "definitionFile": "feeder.json",
    "definition": {
      "directory": "LocalFeeder",
      "execute_function": "python -m src.localfeeder.sender_cosim",
      "static_inputs": [
        {
          "type": "",
          "port_id": "feeder_file"
        },
        {
          "type": "",
          "port_id": "start_date"
        },
        {
          "type": "",
          "port_id": "run_freq_sec"
        },
        {
          "type": "",
          "port_id": "number_of_timesteps"
        },
        {
          "type": "",
          "port_id": "start_time_index"
        }
      ],
      "dynamic_inputs": [
        {
          "type": "",
          "port_id": "pv_set",
          "optional": true
        },
        {
          "type": "CommandList",
          "port_id": "change_commands",
          "optional": true
        },
        {
          "type": "InverterControlList",
          "port_id": "inv_control",
          "optional": true
        }
      ],
      "dynamic_outputs": [
        {
          "type": "VoltagesMagnitude",
          "port_id": "voltages_magnitude"
        },
        {
          "type": "VoltagesReal",
          "port_id": "voltages_real"
        },
        {
          "type": "VoltagesImaginary",
          "port_id": "voltages_imag"
        },
        {
          "type": "PowersReal",
          "port_id": "powers_real"
        },
        {
          "type": "PowersImaginary",
          "port_id": "powers_imag"
        },
        {
          "type": "Topology",
          "port_id": "topology"
        },
        {
          "type": "Injection",
          "port_id": "injections"
        },
        {
          "type": "",
          "port_id": "load_y_matrix"
        },
        {
          "type": "PowersReal",
          "port_id": "available_power"
        },
        {
          "type": "",
          "port_id": "pv_forecast"
        }
      ]
    },
    "inputSchema": {
      "description": "JSON configuration for the feeder simulator.\n\nSpecial cases S3 sources right now.",
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "use_smartds": {
          "default": false,
          "title": "Use Smartds",
          "type": "boolean"
        },
        "user_uploads_model": {
          "default": false,
          "title": "User Uploads Model",
          "type": "boolean"
        },
        "profile_location": {
          "default": "gadal_ieee123/profiles",
          "title": "Profile Location",
          "type": "string"
        },
        "opendss_location": {
          "default": "gadal_ieee123/qsts",
          "title": "Opendss Location",
          "type": "string"
        },
        "existing_feeder_file": {
          "type": "string",
          "title": "Existing Feeder File"
        },
        "sensor_location": {
          "type": "string",
          "title": "Sensor Location",
          "default": "gadal_ieee123/sensors.json"
        },
        "start_date": {
          "default": "2017-01-01 00:00:00",
          "title": "Start Date",
          "type": "string"
        },
        "number_of_timesteps": {
          "default": 1,
          "title": "Number Of Timesteps",
          "type": "integer"
        },
        "run_freq_sec": {
          "default": 900,
          "title": "Run Freq Sec",
          "type": "number",
          "minimum": 0
        },
        "start_time_index": {
          "default": 0,
          "title": "Start Time Index",
          "type": "integer"
        },
        "topology_output": {
          "default": "topology.json",
          "title": "Topology Output",
          "type": "string"
        },
        "use_sparse_admittance": {
          "default": false,
          "title": "Use Sparse Admittance",
          "type": "boolean"
        },
        "tap_setting": {
          "type": "integer",
          "title": "Tap Setting"
        },
        "open_lines": {
          "items": {
            "type": "string"
          },
          "type": "array",
          "title": "Open Lines"
        }
      },
      "required": [
        "profile_location",
        "opendss_location",
        "start_date",
        "number_of_timesteps"
      ],
      "title": "FeederConfig",
      "type": "object"
    }
  },
  {
    "id": "LinDistFlowComponent",
    "name": "LinDistFlow Algorithm",
    "description": "LinDistFlow optimization algorithm",
    "definitionFile": "lin_dist_flow_algorithm.json",
    "definition": {
      "directory": "lindistflow_federate",
      "execute_function": "python -m src.lindistflow_federate.opf_federate",
      "static_inputs": [
        {
          "type": "",
          "port_id": "name"
        },
        {
          "type": "",
          "port_id": "deltat"
        },
        {
          "type": "",
          "port_id": "control_type"
        },
        {
          "type": "",
          "port_id": "pf_flag"
        }
      ],
      "dynamic_inputs": [
        {
          "type": "VoltagesMagnitude",
          "port_id": "voltages_magnitude"
        },
        {
          "type": "Topology",
          "port_id": "topology"
        },
        {
          "type": "Injection",
          "port_id": "injections"
        }
      ],
      "dynamic_outputs": [
        {
          "type": "CommandList",
          "port_id": "change_commands"
        },
        {
          "type": "VoltagesMagnitude",
          "port_id": "opf_voltages_magnitude"
        }
      ]
    },
    "inputSchema": {
      "$defs": {
        "ControlType": {
          "description": "Enum for different types of DER control modes.",
          "enum": [
            1,
            2,
            3
          ],
          "title": "ControlType",
          "type": "integer"
        }
      },
      "description": "Static configuration parameters defining schema.",
      "properties": {
        "name": {
          "type": "string",
          "title": "Name"
        },
        "deltat": {
          "default": 0.1,
          "minimum": 0.0,
          "title": "Time Step (s)",
          "type": "number"
        },
        "control_type": {
          "$ref": "#/$defs/ControlType",
          "default": 3,
          "title": "Control Type"
        },
        "pf_flag": {
          "default": false,
          "title": "Relaxed Power Flow",
          "type": "boolean"
        }
      },
      "title": "LinDistFlowConfig",
      "type": "object"
    }
  },
  {
    "id": "MeasurementComponent",
