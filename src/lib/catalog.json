    "inputSchema": {
      "title": "OMOOConfig",
      "type": "object",
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "algorithm_parameters": {
          "title": "Algorithm Parameters",
          "type": "object",
          "properties": {
            "Vmax": {
              "title": "Vmax",
              "type": "number",
              "default": 1.05
            },
            "Vmin_act": {
              "title": "Vmin (active)",
              "type": "number",
              "default": 0.95
            },
            "Vmin": {
              "title": "Vmin",
              "type": "number",
              "default": 0.95
            },
            "alpha": {
              "title": "Alpha",
              "type": "number",
              "default": 0.5
            },
            "epsilon": {
              "title": "Epsilon",
              "type": "number",
              "default": 1e-08,
              "minimum": 0
            },
            "nu": {
              "title": "Nu",
              "type": "number",
              "default": 0.016,
              "minimum": 0
            },
            "ratio_t_k": {
              "title": "Ratio t/k",
              "type": "integer",
              "default": 1000,
              "minimum": 1
            },
            "units": {
              "title": "Units",
              "type": "string",
              "enum": [
                "SI",
                "PER_UNIT"
              ],
              "default": "PER_UNIT"
            },
            "base_power": {
              "title": "Base Power",
              "type": "number",
              "default": 100.0
            }
          }
        }
      }
    }
  },
  {
    "id": "DOPFPSOComponent",
    "name": "ORNL DOPF (PSO)",
    "description": "Distribution OPF via Particle Swarm Optimization",
    "definitionFile": "ornl_dopf_pso.json",
    "definition": {
      "directory": "dopf_federate",
      "execute_function": "python -m src.dopf_federate.dopf_federate",
      "static_inputs": [
        {
          "type": "",
          "port_id": "name",
          "description": "Federate name",
          "unit": ""
        },
        {
          "type": "",
          "port_id": "pv_buses",
          "description": "List of PV system bus IDs",
          "unit": ""
        },
        {
          "type": "",
          "port_id": "pv_capacity_kw",
          "description": "PV capacity in kW per system",
          "unit": "kW"
        },
        {
          "type": "",
          "port_id": "algorithm_parameters",
          "description": "PSO parameters",
          "unit": ""
        }
      ],
      "dynamic_inputs": [
        {
          "type": "PowersReal",
          "port_id": "powers_real",
          "description": "Real power measurements from feeder",
          "unit": "kW"
        },
        {
          "type": "PowersImaginary",
          "port_id": "powers_imag",
          "description": "Reactive power measurements from feeder",
          "unit": "kVAR"
        },
        {
          "type": "Topology",
          "port_id": "topology",
          "description": "Network topology with Y-bus",
          "unit": ""
        },
        {
          "type": "VoltagesMagnitude",
          "port_id": "voltages_magnitude",
          "description": "Bus voltage magnitudes from feeder",
          "unit": "V"
        }
      ],
      "dynamic_outputs": [
        {
          "type": "CommandList",
          "port_id": "change_commands",
          "description": "PV reactive power setpoint commands",
          "unit": ""
        }
      ]
    },
    "inputSchema": {
      "title": "ComponentParameters",
      "type": "object",
      "properties": {
        "pv_buses": {
          "title": "PV Buses",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "pv_capacity_kw": {
          "title": "PV Capacity kW",
          "type": "array",
          "items": {
            "type": "number"
          }
        },
        "num_particles": {
          "title": "Num Particles",
          "type": "integer"
        },
        "max_iterations": {
          "title": "Max Iterations",
          "type": "integer"
        }
      },
      "required": [
        "pv_buses",
        "pv_capacity_kw",
        "num_particles",
        "max_iterations"
      ]
    }
  },
  {
