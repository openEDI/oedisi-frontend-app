{
  "$defs": {
    "ControlType": {
      "description": "Enum for different types of DER control modes.",
      "enum": [
        1,
        2,
        3
      ],
      "title": "ControlType",
      "type": "integer"
    }
  },
  "description": "Static configuration parameters defining schema.",
  "properties": {
    "name": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Name"
    },
    "deltat": {
      "default": 0.1,
      "minimum": 0.0,
      "title": "Time Step (s)",
      "type": "number"
    },
    "control_type": {
      "$ref": "#/$defs/ControlType",
      "default": 3,
      "title": "Control Type"
    },
    "pf_flag": {
      "default": true,
      "title": "Run Power Flow",
      "type": "boolean"
    }
  },
  "title": "LinDistFlowConfig",
  "type": "object"
}
